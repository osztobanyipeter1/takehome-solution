{
    "name": "ads/takehome-task",
    "type": "project",
    "scripts": {
        "analyse": "phpstan analyse -c phpstan.neon",
        "format": "php-cs-fixer fix"
    },
    "autoload": {
        "psr-4": {
            "ADS\\TakeHome\\": "src/"
        },
        "exclude-from-classmap": [
            "/test/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "ADS\\TakeHome\\Tests\\": "test/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.59",
        "phpunit/phpunit": "^10.5"
    }
}
